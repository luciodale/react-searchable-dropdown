---
import Callout from "@luciodale/docs-ui-kit/components/Callout.astro";
import CodeBlock from "@luciodale/docs-ui-kit/components/CodeBlock.astro";
import ContentSection from "@luciodale/docs-ui-kit/components/ContentSection.astro";
import { CustomDataDemo } from "../../components/demos/CustomDataDemo";
import DocsPage from "../../layouts/DocsPage.astro";
import "@luciodale/react-searchable-dropdown/src/assets/single-style.css";

export const prerender = true;
---

<DocsPage
	title="Custom Data Demo"
	description="Fetch your own data from any URL and use it as dropdown options."
>
	<ContentSection label="Custom Data" id="custom-data">
		<p class="text-white/60 mb-6">
			Enter a URL that returns a JSON array of strings. The dropdown will populate with
			the fetched data. You can target localhost too.
		</p>

		<div class="rounded-xl border border-white/10 bg-white/[0.02] p-6 sm:p-10 mb-8">
			<CustomDataDemo client:load />
		</div>

		<Callout type="info">
			<p>
				This demo expects the endpoint to return a plain JSON array of strings. The
				library also supports object arrays with <code>label</code>/<code>value</code>
				fields.
			</p>
		</Callout>
	</ContentSection>

	<ContentSection label="The code" id="the-code">
		<CodeBlock
			code={`import { SearchableDropdown } from "@luciodale/react-searchable-dropdown";
import "@luciodale/react-searchable-dropdown/dist/single-style.css";
import { useEffect, useState } from "react";

function RemoteDropdown({ url }: { url: string }) {
  const [value, setValue] = useState<string | undefined>(undefined);
  const [options, setOptions] = useState<string[]>([]);

  useEffect(() => {
    fetch(url)
      .then((res) => res.json())
      .then((data) => setOptions(data));
  }, [url]);

  return (
    <SearchableDropdown
      options={options}
      value={value}
      setValue={setValue}
      placeholder="Select an option"
      dropdownOptionsHeight={312}
      debounceDelay={100}
    />
  );
}`}
			language="tsx"
			filename="CustomDataExample.tsx"
		/>
	</ContentSection>
</DocsPage>
