---
import Callout from "@luciodale/docs-ui-kit/components/Callout.astro";
import ContentSection from "@luciodale/docs-ui-kit/components/ContentSection.astro";
import { SingleSelectDemo } from "../../components/demos/SingleSelectDemo";
import DocsPage from "../../layouts/DocsPage.astro";
import "@luciodale/react-searchable-dropdown/src/assets/single-style.css";

export const prerender = true;
---

<DocsPage
	title="Single Select Demo"
	description="Live single-select dropdown with 100k+ cities."
>
	<ContentSection label="Single Select" id="single-select">
		<p class="text-white/60 mb-4">
			Default theme, string options, zero debounce. The list contains hundreds of thousands
			of cities. Start typing to see the search filter in action.
		</p>

		<SingleSelectDemo client:load />

		<Callout type="info" title="Performance">
			<p>
				This demo loads the full dataset into the browser. Filtering happens entirely
				client-side using match-sorter. The dropdown list is virtualized via Virtuoso,
				so only visible items are rendered regardless of list size.
			</p>
		</Callout>
	</ContentSection>
</DocsPage>
