{
	"compilerOptions": {
		"target": "ES2020",
		"lib": ["ES2020", "DOM", "DOM.Iterable"],
		"module": "ESNext",
		"moduleResolution": "bundler",
		"jsx": "react-jsx",
		"strict": true,
		"skipLibCheck": true,
		"isolatedModules": true,
		"noEmit": true,
		"types": ["vitest/globals"]
	},
	"include": [
		"packages/library/src/**/*.test.ts",
		"packages/library/src/**/*.test.tsx",
		"packages/library/src/test-setup.ts"
	]
}
